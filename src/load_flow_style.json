[
  {
    "id": "bus-lines",
    "name": "Bus Lines",
    "type": "line",
    "paint": {
      "line-color": "rgb(210,2,29)",
      "line-width": 2
    }
  },
  {
    "id": "bus-lines-label",
    "name": "Bus Line Label",
    "type": "symbol",
    "layout": {
      "symbol-placement": "line",
      "text-field": ["get", "p_from_kw"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 15
    },
    "paint": {
      "text-color": "black",
      "text-halo-blur": 10,
      "text-halo-width": 10,
      "text-halo-color": "white"
    }
  },
  {
    "id": "bus-points",
    "name": "Bus Points",
    "type": "circle",
    "minzoom": 12,
    "paint": {
      "circle-radius": 10,
      "circle-color": "rgb(0,200,2)",
      "circle-stroke-color": "white",
      "circle-stroke-width": 1
    },
    "filter": ["==", "type", "bus"]
  },
  {
    "id": "bus-points-label",
    "name": "Bus Points Label",
    "type": "symbol",
    "minzoom": 12,
    "layout": {
      "text-field": ["get", "vm_pu"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 12
    },
    "paint": {
      "text-color": "black"
    },
    "filter": ["==", "type", "bus"]
  }
]
