[
  {
    "id": "power-line-label",
    "name": "Active power by Line",
    "type": "symbol",
    "minzoom": 8,
    "layout": {
      "symbol-placement": "line",
      "text-field": ["concat",["get", "p_from_kw"], " kW"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 15
    },
    "paint": {
      "text-color": "red",
      "text-halo-blur": 10,
      "text-halo-width": 10,
      "text-halo-color": "white"
    }
  },
  {
    "id": "voltage-heatmap",
    "name": "Voltage Heatmap",
    "type": "circle",
    "minzoom": 12,
    "paint": {
      "circle-radius": 50,
      "circle-color": [
        "interpolate",
        ["linear"],
        ["to-number",["get", "vm_pu"]],
        0.94,
        "rgb(0,145,231)",
        1.0,
        "rgb(0,200,2)",
        1.06,
        "rgb(210,2,29)"
      ],
      "circle-opacity": 0.03
    },
   "filter": ["==", "type", "bus"]
  },
  {
    "id": "bus-voltage-label",
    "name": "Bus Voltage [p.u] ",
    "type": "symbol",
    "minzoom": 15,
    "layout": {
      "text-field":["concat",["get", "vm_pu"]," pu"],
      "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
      "text-size": 15
    },
    "paint": {
      "text-color": "black"
    },
	"filter": ["==", "type", "bus"]
  }
]
